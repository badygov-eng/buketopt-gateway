# Секреты лучше хранить в ~/.secrets/buketopt-gateway/env и source при деплое
GATEWAY_API_KEYS=change-me-dev-key
GATEWAY_BITRIX_BASE_URL=https://ai-test.buketopt.ru
GATEWAY_BITRIX_HTTP_TIMEOUT_SEC=45
GATEWAY_BITRIX_VERIFY_TLS=false
GATEWAY_DEFAULT_PAYMENT_METHOD_ID=15
# Осторожно: ослабляет валидацию Bitrix
GATEWAY_USE_SIMPLE_ORDER=false
